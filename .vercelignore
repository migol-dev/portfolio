# Vercel Build Ignore List
# Files and directories that won't be uploaded to Vercel

# Git
.git
.gitignore

# Development
.env
.env.local
.env.local.example
.env.example

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Documentation
VERCEL_DEPLOYMENT.md
CLAUDE.md
AGENTS.md

# Build artifacts (will be recreated)
.next
.turbo
dist
build

# Dependencies (installed fresh)
node_modules
.pnp

# Test
.nyc_output
coverage
*.lcov

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Prisma
prisma/migrations
prisma/dev.db
